{
  "name": "hydejack",
  "version": "6.4.0",
  "description": "Hydejack is a pretentious two-column [Jekyll](http://jekyllrb.com) theme, stolen by [`@qwtel`](https://twitter.com/qwtel) from [Hyde](http://hyde.getpoole.com). You could say it was.. [hydejacked](http://media3.giphy.com/media/makedRIckZBW8/giphy.gif).",
  "scripts": {
    "clean": "rm -f assets/js/hydejack.js assets/js/hydejack.min.js assets/js/hydejack.js.map",
    "test": "echo \"Warning: no test specified\" && exit 0",
    "build": "npm run build:js",
    "build:js": "node ./scripts/build-js.mjs",
    "watch": "npm run watch:js",
    "watch:js": "node ./scripts/build-js.mjs --watch",
    "lint": "npm run lint:js",
    "lint:js": "eslint _js/src",
    "dev": "npm run watch:js",
    "verify:js": "npm run lint:js && npm run test && npm run clean && npm run build:js",
    "resume": "json2yaml _data/resume.json > _data/resume.yml"
  },
  "author": "Florian Klampfer <f.klampfer@gmail.com> (https://qwtel.com)",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.25.0",
    "eslint": "4.18.2",
    "eslint-config-airbnb": "15.0.1",
    "eslint-plugin-import": "2.3.0",
    "eslint-plugin-jsx-a11y": "5.0.3",
    "eslint-plugin-react": "7.1.0",
    "json2yaml": "1.1.0"
  },
  "dependencies": {
    "color": "1.0.3",
    "core-js": "2.4.1",
    "elem-dataset": "1.1.1",
    "katex": "0.7.1",
    "rxjs": "5.4.1",
    "web-animations-js": "2.2.5",
    "y-drawer": "6.1.1",
    "y-push-state": "6.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qwtel/hydejack.git"
  },
  "bugs": {
    "url": "https://github.com/qwtel/hydejack/issues"
  },
  "homepage": "https://github.com/qwtel/hydejack#readme"
}
